# =============================================================================
# CodeZero Backend — Environment Configuration (EXAMPLE ONLY)
# =============================================================================
#
# Copy to `.env` and replace every placeholder. Never commit `.env` or real secrets.
#
# DO NOT put production values in this file:
#   - OAuth client secrets
#   - JWT signing secrets
#   - Database passwords
#   - Resend / third-party API keys
#
# Required at boot (see src/config/env.ts): DATABASE_URL, JWT_SECRET
# Official contact: whiletrue.codes@gmail.com
# =============================================================================

# --- Runtime ---
NODE_ENV=development
PORT=3000

# --- Database (PostgreSQL — Prisma system of record) ---
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/codezero

# --- Authentication (JWT access tokens; single-session model) ---
# Generate: openssl rand -base64 48
JWT_SECRET=replace-with-a-long-random-secret-min-32-chars
JWT_EXPIRES_IN=7d

# --- CORS & frontend origin (browser API access) ---
# Dev: comma-separated Vite origins
# CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173
# FRONTEND_URL=http://localhost:5173
# Production: single public origin only (auto dev ports disabled when NODE_ENV=production)
# FRONTEND_URL=https://your-production-domain.example
# CORS_ORIGIN=https://your-production-domain.example

# --- OAuth (optional until social login is enabled) ---
# Google: same Client ID as frontend VITE_GOOGLE_CLIENT_ID
# GOOGLE_CLIENT_ID=
# GitHub production app:
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GITHUB_REDIRECT_URI=https://your-production-domain.example/auth/github/callback
# Dev GitHub app (used when NODE_ENV != production and both LOCAL vars are set):
# GITHUB_CLIENT_ID_LOCAL=
# GITHUB_CLIENT_SECRET_LOCAL=
# GITHUB_REDIRECT_URI_LOCAL=http://localhost:5173/auth/github/callback

# --- Email / OTP (Resend — transactional verification) ---
# RESEND_API_KEY=re_xxxxxxxx
# Production FROM (verified domain required):
# EMAIL_FROM=CodeZero <noreply@your-verified-domain.com>
# Dev/test only (Resend sandbox — restrict recipients):
# EMAIL_FROM=CodeZero <onboarding@resend.dev>
# OTP_EXPIRY_MINUTES=10
# OTP_MAX_ATTEMPTS=5
# OTP_RESEND_COOLDOWN_SEC=60
# OTP_RATE_LIMIT_PER_HOUR=8
# EMAIL_OTP_LOG_CONSOLE=false

# Postman/dev only: POST /api/v1/dev/email/test (header x-email-test-secret)
# EMAIL_TEST_SECRET=replace-with-long-random-string

# --- Compiler / code execution (BullMQ + Redis + Docker worker) ---
# Start Redis: docker compose -f docker-compose.compiler.yml up -d
# Start worker: npm run compiler:worker
REDIS_URL=redis://127.0.0.1:6379
# COMPILER_QUEUE_NAME=compiler-execution
# COMPILER_JOB_ATTEMPTS=3
# COMPILER_JOB_TIMEOUT_MS=30000
# COMPILER_EXECUTION_TIMEOUT_SEC=10
# COMPILER_DOCKER_MEMORY=256m
# COMPILER_DOCKER_CPUS=0.5
# COMPILER_DOCKER_PIDS_LIMIT=64
# COMPILER_MAX_CODE_BYTES=65536
# COMPILER_STALE_RUNNING_MS=600000

# --- Operations & catalog (optional) ---
# PRISMA_LOG_QUERIES=true
# LEETCODE_DUMP_TOKEN=replace-with-long-random-string
# LEETCODE_DUMP_DELAY_MS=350

# Daily LeetCode POTD sync (in-process cron on API — keep PM2 instances: 1)
# DAILY_POTD_CRON_ENABLED=true
# DAILY_POTD_CRON_EXPRESSION=0 6 * * *
# DAILY_POTD_CRON_TIMEZONE=Asia/Kolkata
# Manual once: npm run sync:daily-potd

# After migrations: npm run db:seed
# Forum seed: npm run db:seed:forum
