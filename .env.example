# Copy to `.env` and fill in values. Never commit real secrets.

# PostgreSQL connection string used by Prisma
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/leetcode_learning

# HTTP port (optional — defaults to 3000)
PORT=3000

# JWT HMAC secret — login/session tokens only (NOT for email OTP)
JWT_SECRET="replace-with-a-long-random-secret"

# Access token lifetime (`jsonwebtoken` expiresIn string, e.g. "7d", "24h", "3600"). Optional — defaults to "7d" in code.
JWT_EXPIRES_IN="7d"

# Optional: log Prisma SQL to the console (debugging DB writes)
# PRISMA_LOG_QUERIES=true

# After migrations: seed schedule templates (`npm run db:seed` or `npx prisma db seed`)

# Optional: protect LeetCode dump APIs (catalog, details, neetcode-150; header `x-leetcode-dump-token`)
# LEETCODE_DUMP_TOKEN=replace-with-long-random-string
# LEETCODE_DUMP_DELAY_MS=350

# Daily LeetCode POTD sync (same as GET /api/v1/daily-problem) — runs inside the API server
# DAILY_POTD_CRON_ENABLED=true
# DAILY_POTD_CRON_EXPRESSION=0 6 * * *
# DAILY_POTD_CRON_TIMEZONE=Asia/Kolkata
# Manual once: npm run sync:daily-potd

# Community forum seed (after migrate): npm run db:seed:forum

# Optional: comma-separated browser origins for CORS allowlist (production)
# CORS_ORIGIN=http://localhost:5173

# OAuth (backend)
# GOOGLE_CLIENT_ID=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# FRONTEND_URL=http://localhost:5173

# Email (Resend) — OTP for verify / forgot / change password (NOT JWT_SECRET)
# Get key: https://resend.com/api-keys (starts with re_)
# RESEND_API_KEY=re_xxxxxxxx
# EMAIL_FROM=CodeZero <onboarding@resend.dev>
# OTP_EXPIRY_MINUTES=10
# OTP_MAX_ATTEMPTS=5
# OTP_RESEND_COOLDOWN_SEC=60
# OTP_RATE_LIMIT_PER_HOUR=8
# Dev: force console OTP even when RESEND_API_KEY is set (default: send email if key is set)
# EMAIL_OTP_LOG_CONSOLE=true

# --- Compiler / code execution (BullMQ + Docker workers) ---
# Start Redis: docker compose -f docker-compose.compiler.yml up -d
# Start worker (separate terminal): npm run compiler:worker
REDIS_URL=redis://127.0.0.1:6379
# COMPILER_QUEUE_NAME=compiler-execution
# COMPILER_JOB_ATTEMPTS=3
# COMPILER_JOB_TIMEOUT_MS=30000
# COMPILER_EXECUTION_TIMEOUT_SEC=10
# COMPILER_DOCKER_MEMORY=256m
# COMPILER_DOCKER_CPUS=0.5
# COMPILER_MAX_CODE_BYTES=65536
