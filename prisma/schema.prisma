// Prisma schema: single source of truth for DB shape.
// We use PostgreSQL + UUID PKs for merge-friendly IDs at scale (sharding-friendly patterns later).

generator client {
  provider = "prisma-client-js"
}

// Connection URL lives in `prisma.config.ts` (Prisma ORM 7+) so Migrate and the JS driver share one source of truth.
datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Scheduling: template-driven (NOT a generic todo row).
// `ScheduleTemplate` = catalog (POTD, topics, study plans, future AI plans).
// `UserSchedule`     = user enrollment + per-user knobs (count, difficulty) where allowed.
// ---------------------------------------------------------------------------

enum ScheduleType {
  DAILY_POTD
  TOPIC
  STUDY_PLAN
}

/** Per-user practice knobs; separate from `ProblemDifficulty` on the `Problem` model. */
enum DifficultyLevel {
  EASY
  MEDIUM
  HARD
  MIXED
}

model ScheduleTemplate {
  id               String       @id @default(uuid()) @db.Uuid
  name             String
  slug             String       @unique
  type             ScheduleType
  /** System rows ship with the product; user-defined templates can appear later (e.g. AI). */
  isSystem         Boolean      @default(false)
  allowsDifficulty Boolean      @default(true)
  allowsCount      Boolean      @default(true)
  /** Used when `allowsCount` is false (e.g. POTD always 1). */
  defaultCount     Int?
  createdAt        DateTime     @default(now())

  userSchedules      UserSchedule[]
  templateProblems   TemplateProblem[]

  @@map("schedule_templates")
}

/** Per-problem learning state for a schedule on a calendar day (source of truth for progress). */
enum AssignmentStatus {
  PENDING
  SOLVED
  MISSED
  SKIPPED
}

model UserSchedule {
  id               String            @id @default(uuid()) @db.Uuid
  userId           String            @db.Uuid
  templateId       String            @db.Uuid
  active           Boolean           @default(true)
  dailyQuestions   Int?
  difficulty       DifficultyLevel?
  createdAt        DateTime          @default(now())

  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  template     ScheduleTemplate @relation(fields: [templateId], references: [id], onDelete: Restrict)
  assignments  Assignment[]

  /** One enrollment per user per template (e.g. cannot add "Binary Search" twice). */
  @@unique([userId, templateId])
  @@index([userId])
  @@map("user_schedules")
}

enum AuthProvider {
  EMAIL
  GOOGLE
  GITHUB
}

model User {
  id        String   @id @default(uuid()) @db.Uuid
  email     String   @unique
  name      String?
  avatar    String?
  provider  AuthProvider @default(EMAIL)
  googleId  String?  @unique
  githubId  String?  @unique
  /** bcrypt hash — null for OAuth-only accounts */
  password  String?
  /**
   * Last issued access JWT (single session). `requireAuth` checks Bearer token === this value.
   */
  currentAccessToken String? @db.Text
  createdAt          DateTime @default(now())

  userSchedules        UserSchedule[]
  compilerSubmissions  CompilerSubmission[]
  judgeSubmissions     JudgeSubmission[]
  solvedProblems       UserProblemSolve[]
  assignments          Assignment[]
  brainCachePlaylists  BrainCachePlaylist[]
  brainCacheRevisionTasks BrainCacheRevisionTask[]
  autoRevisions        AutoRevision[]

  @@map("users")
}

// ---------------------------------------------------------------------------
// Compiler / code execution (isolated domain — API → queue → Docker workers).
// ---------------------------------------------------------------------------

enum SubmissionStatus {
  QUEUED
  RUNNING
  ACCEPTED
  WRONG_ANSWER
  RUNTIME_ERROR
  COMPILATION_ERROR
  TIME_LIMIT_EXCEEDED
  INTERNAL_ERROR
}

model CompilerSubmission {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String?          @db.Uuid
  language  String
  code      String           @db.Text
  stdin     String?          @db.Text
  stdout    String?          @db.Text
  stderr    String?          @db.Text
  status    SubmissionStatus @default(QUEUED)
  runtimeMs Int?
  memoryKb  Int?
  exitCode  Int?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("compiler_submissions")
}

/** Online judge: sample (visible) vs full (all testcases). */
enum JudgeMode {
  RUN_SAMPLE
  FULL_JUDGE
}

/**
 * User submission for problem-based judge (not playground stdin).
 * Processed by compiler worker via BullMQ.
 */
model JudgeSubmission {
  id           String           @id @default(uuid()) @db.Uuid
  userId       String           @db.Uuid
  problemId    String           @db.Uuid
  language     String
  code         String           @db.Text
  mode         JudgeMode
  status       SubmissionStatus @default(QUEUED)
  /** Per-testcase results: [{ index, passed, input?, expected?, actual?, error? }] */
  testResults  Json?
  stderr       String?          @db.Text
  stdout       String?          @db.Text
  /** User solution CPU/wall inside harness (max testcase ms). Same semantic as executionTimeMs. */
  runtimeMs        Int?
  queueTimeMs      Int?
  compileTimeMs    Int?
  executionTimeMs  Int?
  /** Worker wall: pickup → finalize (includes queue wait if measured end-to-end). */
  totalTimeMs      Int?
  /** Docker run wall (compile + all tests + container overhead). */
  sandboxWallMs    Int?
  exitCode         Int?
  codingDurationMs Int?
  createdAt        DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  problem           Problem      @relation(fields: [problemId], references: [id], onDelete: Cascade)
  solvedAssignments Assignment[] @relation("AssignmentSolvedSubmission")

  @@index([userId])
  @@index([problemId])
  @@index([status])
  @@index([userId, createdAt])
  @@map("judge_submissions")
}

/**
 * Delivered practice item — one row per (user, schedule, problem, calendar day).
 * Synced when today's problems are resolved; updated to SOLVED on accepted full submit.
 */
model Assignment {
  id                 String           @id @default(uuid()) @db.Uuid
  userId             String           @db.Uuid
  problemId          String           @db.Uuid
  userScheduleId     String           @db.Uuid
  assignedDate       DateTime         @db.Date
  status             AssignmentStatus @default(PENDING)
  solvedAt           DateTime?
  solvedSubmissionId String?          @db.Uuid
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  problem          Problem          @relation(fields: [problemId], references: [id], onDelete: Cascade)
  userSchedule     UserSchedule     @relation(fields: [userScheduleId], references: [id], onDelete: Cascade)
  solvedSubmission JudgeSubmission? @relation("AssignmentSolvedSubmission", fields: [solvedSubmissionId], references: [id], onDelete: SetNull)

  @@unique([userId, problemId, userScheduleId, assignedDate])
  @@index([userId])
  @@index([userId, assignedDate])
  @@index([userId, status])
  @@index([assignedDate])
  @@index([status])
  @@index([createdAt])
  @@map("assignments")
}

model UserProblemSolve {
  id                 String   @id @default(uuid()) @db.Uuid
  userId             String   @db.Uuid
  problemId          String   @db.Uuid
  solvedAt           DateTime @default(now())
  solvedSubmissionId String   @db.Uuid

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  problem Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@unique([userId, problemId])
  @@index([userId])
  @@index([problemId])
  @@map("user_problem_solves")
}

// ---------------------------------------------------------------------------
// LeetCode problem catalog (POTD sync today; full library sync later).
// Normalized rows only — never store raw GraphQL payloads.
// ---------------------------------------------------------------------------

model Problem {
  id          String          @id @default(uuid()) @db.Uuid
  leetcodeId  Int             @unique
  title       String
  slug        String          @unique
  difficulty  DifficultyLevel
  topics      String[]
  isPremium   Boolean         @default(false)

  /** Full LeetCode `content` HTML — stored for re-parsing / AI; never returned from public APIs. */
  rawContent       String? @db.Text
  /** Plain-text statement extracted from HTML (best-effort). */
  parsedStatement  String? @db.Text
  /** Raw `exampleTestcases` string from LeetCode (newline-separated). */
  exampleTestcases String? @db.Text
  /** Structured examples for API/UI — persisted from LeetCode `exampleTestcaseList` + parser. */
  examples         Json?
  constraints      String[]
  hints            String[]

  createdAt   DateTime        @default(now())

  /** Calendar rows when this problem was LeetCode POTD (one row per challenge date). */
  dailyPotdEntries   DailyPotd[]
  /** Study plans / topics that include this problem (Blind 75, NeetCode 150, …). */
  templateProblems   TemplateProblem[]
  codeTemplates      ProblemCodeTemplate[]
  judgeTestcases     ProblemTestcase[]
  judgeSubmissions   JudgeSubmission[]
  userSolves         UserProblemSolve[]
  assignments        Assignment[]
  brainCacheEntries  BrainCachePlaylistProblem[]
  brainCacheTasks    BrainCacheRevisionTask[]
  autoRevisions      AutoRevision[]

  @@map("problems")
}

// ---------------------------------------------------------------------------
// Brain Cache — spaced-repetition playlists (independent from schedules/assignments).
// ---------------------------------------------------------------------------

enum BrainCacheRevisionStatus {
  PENDING
  DUE
  OVERDUE
  COMPLETED
  SKIPPED
}

model BrainCachePlaylist {
  id                   String   @id @default(uuid()) @db.Uuid
  userId               String   @db.Uuid
  name                 String
  /** Revisit every N calendar days after last completion (or first add). */
  revisionIntervalDays Int      @default(7)
  /** Optional ISO date strings `YYYY-MM-DD` for one-off revision days. */
  customRevisionDates  Json?
  notifyEmail          Boolean  @default(false)
  notifyWhatsapp       Boolean  @default(false)
  notifyInApp          Boolean  @default(true)
  notifyPush           Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user     User                        @relation(fields: [userId], references: [id], onDelete: Cascade)
  problems BrainCachePlaylistProblem[]
  tasks    BrainCacheRevisionTask[]

  @@index([userId])
  @@map("brain_cache_playlists")
}

model BrainCachePlaylistProblem {
  id         String   @id @default(uuid()) @db.Uuid
  playlistId String   @db.Uuid
  problemId  String   @db.Uuid
  addedAt    DateTime @default(now())

  playlist BrainCachePlaylist       @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  problem  Problem                    @relation(fields: [problemId], references: [id], onDelete: Cascade)
  tasks    BrainCacheRevisionTask[]

  @@unique([playlistId, problemId])
  @@index([playlistId])
  @@index([problemId])
  @@map("brain_cache_playlist_problems")
}

model BrainCacheRevisionTask {
  id                String                   @id @default(uuid()) @db.Uuid
  userId            String                   @db.Uuid
  playlistId        String                   @db.Uuid
  playlistProblemId String                   @db.Uuid
  problemId         String                   @db.Uuid
  dueDate           DateTime                 @db.Date
  completedAt       DateTime?
  status            BrainCacheRevisionStatus @default(PENDING)
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt

  user            User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  playlist        BrainCachePlaylist        @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  playlistProblem BrainCachePlaylistProblem @relation(fields: [playlistProblemId], references: [id], onDelete: Cascade)
  problem         Problem                   @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@unique([playlistProblemId, dueDate])
  @@index([userId])
  @@index([userId, dueDate])
  @@index([userId, status])
  @@index([playlistId])
  @@index([dueDate])
  @@index([status])
  @@map("brain_cache_revision_tasks")
}

// ---------------------------------------------------------------------------
// Smart Auto-Revision (separate from manual Brain Cache playlists).
// ---------------------------------------------------------------------------

enum AutoRevisionType {
  DAILY
  WEEKLY
  MONTHLY
}

model AutoRevision {
  id            String           @id @default(uuid()) @db.Uuid
  userId        String           @db.Uuid
  problemId     String           @db.Uuid
  problemTitle  String
  difficulty    DifficultyLevel
  solvedAt      DateTime
  revisionType  AutoRevisionType
  scheduledFor  DateTime         @db.Date
  isRevised     Boolean          @default(false)
  revisedAt     DateTime?
  /** IANA timezone used when computing scheduledFor (e.g. America/New_York). */
  scheduleTimezone String        @default("UTC")
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  problem Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@unique([userId, problemId, revisionType])
  @@index([userId, scheduledFor])
  @@index([userId, isRevised, scheduledFor])
  @@map("auto_revisions")
}

/** Per-language starter body; user never writes main() — harness is generated. */
model ProblemCodeTemplate {
  id           String   @id @default(uuid()) @db.Uuid
  problemId    String   @db.Uuid
  language     String
  starterCode  String   @db.Text
  functionName String
  /**
   * Optional JSON array of argument type hints for C++/Java judges, e.g. ["int[]","int","String"].
   * Required for C++/Java judge harness codegen when not using interpreted languages.
   */
  judgeArgHints String? @db.Text
  createdAt    DateTime @default(now())

  problem Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@unique([problemId, language])
  @@index([problemId])
  @@map("problem_code_templates")
}

/** Testcases for judge; visible ones run on “Run”, all run on “Submit”. */
model ProblemTestcase {
  id             String   @id @default(uuid()) @db.Uuid
  problemId      String   @db.Uuid
  /** JSON string: {\"args\":[...]} — function arguments excluding `self`. */
  input          String   @db.Text
  /** JSON string of expected return value */
  expectedOutput String   @db.Text
  isHidden       Boolean  @default(false)
  orderIndex     Int

  problem Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@index([problemId, orderIndex])
  @@map("problem_testcases")
}

/**
 * Ordered problem list for a schedule template (Blind 75, NeetCode 150, Binary Search pool, …).
 * Admin segregation: same `Problem` row can appear in multiple templates via separate links.
 */
model TemplateProblem {
  id         String @id @default(uuid()) @db.Uuid
  templateId String @db.Uuid
  problemId  String @db.Uuid
  /** 1-based display order within the plan (Blind 75 #1 … #75). */
  order      Int

  template ScheduleTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  problem  Problem          @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@unique([templateId, problemId])
  @@unique([templateId, order])
  @@index([problemId])
  @@map("template_problems")
}

/**
 * LeetCode daily challenge calendar: exactly one official POTD per `challengeDate`.
 * Separates "was POTD on this day" from generic `problems` catalog (study plans come later).
 */
model DailyPotd {
  id            String   @id @default(uuid()) @db.Uuid
  /** LeetCode challenge date (from `activeDailyCodingChallengeQuestion.date`). */
  challengeDate DateTime @unique @db.Date
  problemId     String   @db.Uuid
  createdAt     DateTime @default(now())

  problem Problem @relation(fields: [problemId], references: [id], onDelete: Restrict)

  @@index([problemId])
  @@map("daily_potd")
}
