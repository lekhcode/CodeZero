{
  "name": "leetcode-learning-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Backend foundation for an AI-powered LeetCode learning platform",
  "type": "module",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "compiler:worker": "tsx src/compiler/workers/bootstrap.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "sync:blind-75": "tsx scripts/sync-study-plan.ts blind-75",
    "sync:top-interview-150": "tsx scripts/sync-study-plan.ts top-interview-150",
    "test:parser": "tsx src/modules/leetcode/leetcode.parser.test.ts",
    "test:judge:compare": "tsx src/compiler/judge/judgeOutputCompare.test.ts",
    "refresh:examples": "tsx scripts/refresh-problem-examples.ts",
    "judge:benchmark": "tsx scripts/judge-benchmark.ts",
    "refresh:examples:plans": "tsx scripts/refresh-problem-examples.ts -- --plans=blind-75,top-interview-150",
    "test:compiler": "node scripts/test-compiler.mjs http://localhost:2026",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bullmq": "^5.67.2",
    "bcrypt": "^6.0.0",
    "ioredis": "^5.9.3",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0",
    "pino": "^9.14.0",
    "pino-http": "^10.5.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.19.0",
    "@types/pg": "^8.20.0",
    "pino-pretty": "^13.1.1",
    "prisma": "^7.8.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
